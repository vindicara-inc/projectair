# Flightdeck data source: "live" calls the AIR API; set "mock" for offline UI fixtures.
PUBLIC_AIR_API_MODE=live

# Live mode API origin (local dev: http://127.0.0.1:8000)
PUBLIC_AIR_API_BASE=https://api.vindicara.io

# Auth0 (lock screen -> Universal Login). Required for live session guard.
# Map from server-side AIR_AUTH0_* used by the delegation CLI:
#   PUBLIC_AUTH0_DOMAIN      <- AIR_AUTH0_DOMAIN
#   PUBLIC_AUTH0_CLIENT_ID   <- Auth0 SPA client (not the CLI machine client)
#   PUBLIC_AUTH0_AUDIENCE    <- AIR_AUTH0_AUDIENCE
PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
PUBLIC_AUTH0_CLIENT_ID=your-spa-client-id
PUBLIC_AUTH0_AUDIENCE=https://api.vindicara.io
